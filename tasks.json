{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build packet sniffer",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/gcc.exe",
            "args": [
                "-g",
                "-IE:/npcap/Include",
                "-LE:/npcap/Lib/x64",
                "packet_sniffer.c",
                "-o",
                "packet_sniffer.exe",
                "-lwpcap",
                "-lws2_32"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}